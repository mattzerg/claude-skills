{
  "manifest_version": 3,
  "name": "ZergGuard URL Shield",
  "version": "0.1.0",
  "description": "Real-time URL check against ZergGuard local IOC list. Warns before known-bad domains load.",
  "permissions": ["activeTab", "tabs", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZergGuard URL Shield"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html"
}
