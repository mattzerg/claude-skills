    "ed6fe0196222ae89": [
      {
        "rule": "Open with the tension or payoff, not the backstory",
        "why": "Readers decide in the first sentence whether to continue; context earns its place only after the hook exists.",
        "when": "Blog post introductions, email subject lines, launch copy headlines",
        "example_before": "We've been building this for six months and thinking hard about the problem space before we finally arrived at\u2026",
        "example_after": "Most analytics tools lie to you. Here's what we built instead."
      },
      {
        "rule": "Cut throat-clearing phrases ('I wanted to share', 'I thought it might be worth', 'just a quick note')",
        "why": "These phrases signal uncertainty and dilute the authority of what follows.",
        "when": "Professional emails, outreach messages, any first paragraph",
        "example_before": "I just wanted to quickly share something I thought might be interesting to you.",
        "example_after": "Here's something worth your attention."
      },
      {
        "rule": "Name the reader's problem before naming your solution",
        "why": "People scan for evidence you understand them before they trust you to fix anything.",
        "when": "Product launch copy, cold outreach, landing page above-the-fold text",
        "example_before": "Introducing FastPipe \u2014 a new way to move data.",
        "example_after": "Your data pipeline breaks every time the schema changes. FastPipe fixes that."
      },
      {
        "rule": "Replace 'very', 'really', and 'quite' with a stronger word or nothing",
        "why": "Intensifiers weaken the noun or adjective they modify by signaling it couldn't carry the weight alone.",
        "when": "All professional writing",
        "example_before": "This is a really important decision that will have a very significant impact.",
        "example_after": "This decision will reshape how the team ships."
      },
      {
        "rule": "Use active voice; make the agent the subject",
        "why": "Passive constructions hide accountability and slow the reader down.",
        "when": "All professional writing, especially announcements and instructions",
        "example_before": "Mistakes were made and lessons have been learned by the team.",
        "example_after": "We made mistakes and learned from them."
      },
      {
        "rule": "Shorten sentences that run past two clauses",
        "why": "Long multi-clause sentences force the reader to hold too much in working memory at once.",
        "when": "Blog posts, email body copy, any writing meant to be scanned",
        "example_before": "We looked at the data, which showed a trend, and decided to act on it, which led to the result we wanted.",
        "example_after": "The data showed a clear trend. We acted on it. It worked."
      },
      {
        "rule": "Pick one call to action per email; remove secondary asks",
        "why": "Multiple asks diffuse attention and reduce the chance any single one gets done.",
        "when": "Outreach emails, follow-up messages, newsletter CTAs",
        "example_before": "Let me know your thoughts, and also feel free to share with others, and book time if you want to chat.",
        "example_after": "If this resonates, book 20 minutes here."
      },
      {
        "rule": "End with the ask or the next step, not a summary",
        "why": "Summaries signal the writer is done; a concrete next step pulls the reader forward.",
        "when": "Emails, proposals, blog post conclusions",
        "example_before": "So in summary, we covered X, Y, and Z. Hope this was helpful!",
        "example_after": "Try it on your next draft and see what changes."
      },
      {
        "rule": "Replace jargon with the plain word your audience already uses",
        "why": "Borrowed jargon signals you're performing expertise rather than demonstrating it.",
        "when": "Cross-functional emails, blog posts, any writing for a mixed audience",
        "example_before": "We need to leverage our core competencies to ideate around the opportunity space.",
        "example_after": "We should use what we're already good at to find new opportunities."
      },
      {
        "rule": "Show the specific number; don't describe the magnitude",
        "why": "Vague magnitude words ('significant', 'huge', 'major') are reader-relative; numbers anchor meaning.",
        "when": "Results announcements, launch copy, investor or stakeholder updates",
        "example_before": "We saw a significant improvement in load time after the change.",
        "example_after": "Load time dropped from 4.2 s to 0.9 s."
      },
      {
        "rule": "Match sentence length to emotional pace: short for emphasis, longer for texture",
        "why": "Monotone sentence length flattens the reading experience and buries your most important points.",
        "when": "Blog posts, essays, narrative sections of longer emails",
        "example_before": "The launch went well. People liked it. We hit our goals. It was a good day.",
        "example_after": "The launch hit every goal we set. But the part I'll remember: a customer emailed within the first hour to say it fixed the exact problem we'd bet on."
      },
      {
        "rule": "Delete 'I think' and 'I believe' when the sentence already expresses an opinion",
        "why": "Hedging a claim that's already clearly your view signals a lack of conviction.",
        "when": "Professional emails, blog posts, any first-person opinion writing",
        "example_before": "I think this is probably the right approach for most teams.",
        "example_after": "This is the right approach for most teams."
      },
      {
        "rule": "Use contractions in conversational registers; drop them in formal ones",
        "why": "Contractions calibrate warmth and register; mismatched formality sounds robotic or overly casual.",
        "when": "Blog posts and outreach (use contractions); legal, board, or compliance writing (avoid them)",
        "example_before": "We are pleased to announce that we have reached our goal.",
        "example_after": "We're pleased to announce we hit our goal."
      },
      {
        "rule": "State your conclusion first, then support it (inverted pyramid)",
        "why": "Busy readers often stop after the first paragraph; burying the conclusion loses them.",
        "when": "Business emails, memos, analytical blog posts",
        "example_before": "We reviewed the data, consulted the team, and weighed the tradeoffs\u2026 therefore we recommend Option B.",
        "example_after": "We recommend Option B. Here's why."
      },
      {
        "rule": "Cut the word 'just' unless it signals timing or precision",
        "why": "'Just' used as a softener minimizes what you're saying and undermines authority.",
        "when": "All professional writing, especially requests and recommendations",
        "example_before": "I just wanted to check in and see if you'd had a chance to review this.",
        "example_after": "Have you had a chance to review this?"
      },
      {
        "rule": "Don't apologize for the email's length or your reader's time in the opening",
        "why": "Pre-emptive apologies frame the message as an imposition before the reader has formed any view.",
        "when": "All email writing",
        "example_before": "Sorry for the long email, I know you're busy, but I wanted to\u2026",
        "example_after": "Three things I need from you by Thursday:"
      },
      {
        "rule": "Use second person ('you') to address the reader directly rather than 'users' or 'teams'",
        "why": "Generic third-person nouns create distance; 'you' makes the reader feel directly addressed.",
        "when": "Blog posts, marketing copy, outreach emails",
        "example_before": "Teams that adopt this approach tend to see better results.",
        "example_after": "When you adopt this approach, you'll see better results."
      },
      {
        "rule": "Break up noun stacks into 'X that does Y' or 'X for Y' constructions",
        "why": "Stacked nouns compress meaning until it becomes ambiguous or inaccessible.",
        "when": "Technical writing, product descriptions, any domain-heavy prose",
        "example_before": "pipeline execution failure notification system configuration",
        "example_after": "settings for the system that notifies you when a pipeline fails"
      },
      {
        "rule": "Vary paragraph length; avoid three or more consecutive same-length paragraphs",
        "why": "Uniform paragraph length creates a visual and cognitive rhythm that dulls the reader.",
        "when": "Blog posts, longer emails, any document over 300 words",
        "example_before": "",
        "example_after": ""
      },
      {
        "rule": "Spell out what 'this' or 'it' refers to when the antecedent is more than one sentence back",
        "why": "Ambiguous pronouns force backtracking and break reading flow.",
        "when": "All writing, especially technical explanations and multi-step arguments",
        "example_before": "The system processes the event, logs the result, and updates the state. This is why it matters.",
        "example_after": "The system processes the event, logs the result, and updates the state. That audit trail is why the design matters."
      }
    ],
