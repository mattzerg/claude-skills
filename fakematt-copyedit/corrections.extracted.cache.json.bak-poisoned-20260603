    "c5c1679c7ebdb97a": [
      {
        "rule": "Cap em-dashes at \u2264 3 in pieces \u2264 800 words; convert conversational asides to periods",
        "why": "Pulp/social register reads with periods, not em-dashes; dashes dilute when overused",
        "when": "Short-form blog posts (\u2264 800 words) in pulp or social register",
        "example_before": "\u2026trying again \u2014 often with the same broken approach\u2026",
        "example_after": "\u2026trying again. Often with the same broken approach\u2026"
      },
      {
        "rule": "Give sharp single-sentence central-frame claims their own paragraph",
        "why": "White space sells punchlines; burying a key claim mid-paragraph kills its impact",
        "when": "Pulp-register blog posts with a central thesis or memorable frame line",
        "example_before": "The retry loop is the default, and the default is wrong. We notice this at Zerg \u2014 so a new paper\u2026",
        "example_after": "The retry loop is the default, and the default is wrong.\n\nWe notice this at Zerg\u2026"
      },
      {
        "rule": "Keep figure captions \u2264 20 words; use numeric tells when data supports; never restate the body",
        "why": "Pulp social captions are billboards, not paragraphs; redundancy with body wastes reader attention",
        "when": "Any figure/diagram caption in short-form blog or social post",
        "example_before": "Figure 1 shows the pass rate improvement across three phases of the experiment, rising from 22% to 54% as the model learned to correct itself.",
        "example_after": "1,178 \u2192 174 \u2192 78. Single-pass correctness: 22% \u2192 54%."
      },
      {
        "rule": "Name the baseline whenever citing a speedup or improvement metric",
        "why": "Vague baselines are what sharp readers attack; precision is compatible with pulp register",
        "when": "Any performance claim using 'over baseline', 'vs baseline', or 'than baseline'",
        "example_before": "3.12\u00d7 speedup over baseline within 100 steps.",
        "example_after": "3.12\u00d7 over PyTorch eager within 100 steps."
      },
      {
        "rule": "Use exactly one CTA in the closer; keep the more confident and specific one",
        "why": "Two CTAs dilute each other; filler enterprise phrases undercut the post's voice",
        "when": "Pulp blog post closers with any call to action",
        "example_before": "We'd love to compare notes \u2014 or come argue with us about what should and shouldn't transfer.",
        "example_after": "Come argue with us about what should and shouldn't transfer."
      },
      {
        "rule": "Replace 'competitive with X' / 'comparable to X' / 'in line with X' with a verb-forward claim",
        "why": "Pulp register wants verbs; nominal hedges hide the actual result",
        "when": "Any performance or comparison claim in blog, launch copy, or social",
        "example_before": "competitive with vendor-optimized code",
        "example_after": "as fast as vendor-optimized code"
      },
      {
        "rule": "Route gap-admission / strategic-disclosure lines to a separate 'Strategic disclosure' section, not writing-quality findings",
        "why": "Whether to admit a gap is a strategic call for the author/CEO, not a copyedit judgment",
        "when": "Any review of external-facing copy that contains a 'we don't have X yet' type admission",
        "example_before": "",
        "example_after": ""
      },
      {
        "rule": "When a draft title uses 'What X Gets Wrong About Y' or a curiosity-gap shape, check if a flat declarative version exists in the body or share copy and recommend it as primary",
        "why": "Flat declaratives are sharper and more pulp; curiosity-gap titles are a worn-out pattern",
        "when": "Any blog post or article headline in pulp or social register",
        "example_before": "What AI Agents Get Wrong About Failure",
        "example_after": "Most AI Agents Have No Memory"
      }
    ],
