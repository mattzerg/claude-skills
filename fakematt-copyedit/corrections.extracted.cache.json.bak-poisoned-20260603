        "when": "Any professional writing \u2014 emails, blog posts, launch copy",
        "example_before": "This is a really transformative approach to hiring.",
        "example_after": "This is a transformative approach to hiring."
      },
      {
        "rule": "When you know who acted, name them \u2014 rewrite passive constructions into active ones",
